# =============================================================================
# Block Storage additions — append these to /opt/gentrx-api/.env
# on production server 149.28.145.80
# =============================================================================

# ---- File storage (block volume) ----
FILESYSTEM_DISK=block_storage
BLOCK_STORAGE_ROOT=/mnt/gentrx/uploads
BLOCK_STORAGE_URL=https://api.gentrx.ph/storage

# ---- Patient file limits ----
# These are read by FileUploadService — adjust per compliance requirements
UPLOAD_MAX_DOCTORS_MB=2
UPLOAD_MAX_CLIENTS_MB=2
UPLOAD_MAX_PATIENTS_MB=20
UPLOAD_MAX_SYSTEM_MB=5

# ---- Signed URL TTL for private patient files (seconds) ----
SIGNED_URL_TTL_SECONDS=300

# =============================================================================
# Movider SMS / OTP — append to /opt/gentrx-api/.env
# Credentials from https://platform.movider.net
# =============================================================================
MOVIDER_API_KEY=35sfUcHlupBFggQPx0gKolTeNe7
MOVIDER_API_SECRET=W5x1g5McdWXVJTjgGUfITi7Taqij1JWrIgI8XhGC

# Set to false to bypass phone OTP during development/internal testing.
# Must be true (or absent) in production.
GENTRX_PHONE_VERIFY_REQUIRED=true

