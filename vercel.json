{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://gentrx.ph/api/:path*"
    },
    {
      "source": "/storage/:path*",
      "destination": "https://gentrx.ph/storage/:path*"
    },
    {
      "source": "/:path*((?!\\.\\w+$)(?!__next)[^\\.]+)$",
      "destination": "/index.html"
    }
  ]
}
