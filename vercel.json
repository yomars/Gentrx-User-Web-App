{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/version.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, proxy-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    },
    {
      "source": "/version-live.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, proxy-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/version.json",
      "destination": "/version.json"
    },
    {
      "source": "/version-live.json",
      "destination": "/version-live.json"
    },
    {
      "source": "/api/:path*",
      "destination": "https://api.gentrx.ph/api/:path*"
    },
    {
      "source": "/storage/:path*",
      "destination": "https://api.gentrx.ph/storage/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
