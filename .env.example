# Frontend runtime/build vars (Vercel)
# Apex domain; apiAddress.js falls back to same-origin on www subdomain to avoid CORS issues.
# Vercel rewrites /api/* to backend at apex domain.
VITE_API_ADDRESS="https://gentrx.ph"

VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_MEASUREMENT_ID=""
VITE_FIREBASE_FCM_PUBLIC_KEY=""

# DB automation vars (CI runners only)
# Preferred URL form:
DEST_DATABASE_URL=""

# Or split form:
DEST_DB_HOST=""
DEST_DB_PORT="5432"
DEST_DB_USER=""
DEST_DB_PASSWORD=""
DEST_DB_NAME=""
DEST_DB_SCHEMA="public"
DEST_DB_SSL="true"

# Optional controls
SCHEMA_PATCH_FILE=""
ALLOW_NON_VULTR_PG="false"

# Optional smoke check endpoint for post-deploy verification
API_HEALTHCHECK_URL=""

# Vercel deployment (CI runners and rollback script)
VERCEL_TOKEN=""
VERCEL_ORG_ID=""
VERCEL_PROJECT_ID=""

# GitHub branch protection setup (one-time script only)
# GITHUB_TOKEN must have administration:write + pull_requests:write permissions
GITHUB_TOKEN=""
GITHUB_REPO="owner/repo"
GITHUB_BRANCH="main"
